---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "个人总站",
  description = "一个清爽的个人品牌门面与导航门户。"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
