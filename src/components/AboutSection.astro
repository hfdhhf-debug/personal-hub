---
import { Code2, FileText, Lightbulb } from "lucide-astro";

const points = [
  {
    icon: FileText,
    title: "持续记录",
    description: "写作驱动思考，沉淀可复用的知识。"
  },
  {
    icon: Code2,
    title: "开源分享",
    description: "把工具和项目整理成可以被使用的东西。"
  },
  {
    icon: Lightbulb,
    title: "精益求精",
    description: "关注细节、体验与长期维护。"
  }
];
---

<section class="about" id="about" aria-labelledby="about-title">
  <div class="section-shell about-inner">
    <div class="about-copy">
      <p class="section-kicker">关于本站</p>
      <h2 id="about-title">这里是一个收纳学习、构建与分享的入口。</h2>
      <p>
        它会逐步连接我的博客、导航、作品与工具。第一版先保持轻量，重点是让人快速理解我在做什么，并顺手进入想看的内容。
      </p>
      <a class="text-link" href="#featured">了解更多 <span aria-hidden="true">→</span></a>
    </div>

    <div class="about-points">
      {points.map((point) => {
        const Icon = point.icon;
        return (
          <article class="about-point">
            <Icon size={22} aria-hidden="true" />
            <div>
              <h3>{point.title}</h3>
              <p>{point.description}</p>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
