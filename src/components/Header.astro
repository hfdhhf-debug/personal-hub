---
import { Github, Menu, Moon, Search, Sun, X } from "lucide-astro";

const navItems = [
  { href: "#home", label: "首页" },
  { href: "#featured", label: "精选" },
  { href: "#directory", label: "全部" },
  { href: "#about", label: "关于" }
];
---

<header class="site-header" data-mobile-nav>
  <a class="brand" href="#home" aria-label="回到首页">
    <span class="brand-mark" aria-hidden="true">X</span>
    <span>小站总站</span>
  </a>

  <nav class="desktop-nav" aria-label="主导航">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>

  <div class="header-actions">
    <button class="icon-button" type="button" data-theme-toggle aria-label="切换主题">
      <Moon class="theme-icon theme-icon-moon" size={18} aria-hidden="true" />
      <Sun class="theme-icon theme-icon-sun" size={18} aria-hidden="true" />
    </button>
    <a class="icon-button" href="#featured" aria-label="查看精选入口">
      <Search size={18} aria-hidden="true" />
    </a>
    <a class="icon-button" href="https://github.com/" target="_blank" rel="noreferrer" aria-label="打开 GitHub">
      <Github size={18} aria-hidden="true" />
    </a>
    <button class="icon-button mobile-menu-button" type="button" data-menu-toggle aria-label="打开导航">
      <Menu class="menu-open-icon" size={20} aria-hidden="true" />
      <X class="menu-close-icon" size={20} aria-hidden="true" />
    </button>
  </div>

  <nav class="mobile-nav" aria-label="移动端导航" data-menu-panel>
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
